#!/bin/sh
# Auto-bump Version header in claude-bridge.php to YYYY.MM.DD[.N] on every commit.

FILE="claude-bridge.php"
TODAY=$(date +%Y.%m.%d)

CURRENT=$(grep '^ \* Version:' "$FILE" | sed 's/.*Version: *//')

# If already on today's date, increment the patch counter.
if echo "$CURRENT" | grep -q "^$TODAY"; then
    PATCH=$(echo "$CURRENT" | awk -F. '{print $4}')
    NEXT="$TODAY.$((${PATCH:-0} + 1))"
else
    NEXT="$TODAY"
fi

sed -i "s/^ \* Version:.*/ * Version:     $NEXT/" "$FILE"
git add "$FILE"

echo "[pre-commit] claude-bridge.php version bumped to $NEXT"
